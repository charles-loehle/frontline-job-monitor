{
	"manifest_version": 3,
	"name": "Frontline Job Monitor",
	"version": "1.2",
	"permissions": ["storage"],
	"host_permissions": ["https://*.frontlineeducation.com/*"],
	"content_scripts": [
		{
			"matches": ["https://*.frontlineeducation.com/*"],
			"js": ["content.js"],
			"css": ["styles.css"]
		}
	],
	"action": {
		"default_popup": "popup.html"
	}
}
